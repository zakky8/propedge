# PropEdge v2 Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://propedge.vercel.app
PROPEDGE_API_KEY=your_secure_api_key_here

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ============================================
# Anthropic API Configuration
# ============================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# TradeLocker Configuration
# ============================================
TRADELOCKER_BASE_URL=https://tradelocker.api.com
TRADELOCKER_EMAIL=your-email@example.com
TRADELOCKER_PASSWORD=your_secure_password
TRADELOCKER_SERVER=real
TRADELOCKER_DEMO_BASE_URL=https://demo.tradelocker.api.com

# ============================================
# News APIs Configuration
# ============================================
JBLANKED_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=forexdata.p.rapidapi.com

# ============================================
# Redis/Upstash Configuration
# ============================================
UPSTASH_REDIS_URL=redis://default:your_token@your_host:port
UPSTASH_REDIS_TOKEN=your_upstash_token

# ============================================
# Railway Deployment
# ============================================
# Set Railway-specific variables in your Railway dashboard
# This app is configured for Railway deployment

# ============================================
# Feature Flags
# ============================================
ENABLE_WEBSOCKET=true
ENABLE_AI_COACH=true
NEWS_CACHE_MINUTES=15
RATE_LIMIT_MAX=200
