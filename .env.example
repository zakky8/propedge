# ──────────────────────────────────────────────
# PropEdge Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ──────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# PropEdge API Key (generate a secure random string)
PROPEDGE_API_KEY=your-secure-api-key-here

# ── Supabase (PostgreSQL + Auth) ──────────────
# https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Anthropic (AI Coach) ──────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── TradeLocker API ───────────────────────────
# https://tradelocker.com/developer
TRADELOCKER_BASE_URL=https://demo.tradelocker.com/backend-service
TRADELOCKER_EMAIL=your-tradelocker-email@example.com
TRADELOCKER_PASSWORD=your-tradelocker-password
TRADELOCKER_SERVER=demo.tradelocker.com

# ── News APIs ─────────────────────────────────
# JBlanked: Free, no key needed
# RapidAPI: https://rapidapi.com/search/economic-calendar
RAPIDAPI_KEY=your-rapidapi-key-here

# ── Redis Cache (Upstash — free tier) ─────────
# https://upstash.com → Create Database → REST API
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# ── Railway Deployment ────────────────────────
# Set these in Railway dashboard → Variables
# RAILWAY_STATIC_URL is set automatically by Railway
